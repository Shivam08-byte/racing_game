# AI Service Configuration
# Copy this file to .env and fill in your values

# ==================== AI Services ====================

# Ollama Configuration (for local LLM)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3:latest
OLLAMA_FLAG=False

# Gemini Configuration (for cloud AI)
GOOGLE_API_KEY=your-gemini-api-key-here
GEMINI_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash-lite:generateContent
GEMINI_FLAG=True

# Priority: If OLLAMA_FLAG=True and Ollama is reachable, it will be used.
# Otherwise, if GEMINI_FLAG=True, Gemini will be used.
# If both fail, the app falls back to offline heuristics.

# ==================== Firebase Integration ====================

# Firebase Admin SDK
FIREBASE_CREDENTIALS_PATH=/path/to/firebase-service-account.json
FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"your-project"}
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Firebase Configuration (for client-side)
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abcdef

# ==================== Google Cloud Platform ====================

# GCP Project Configuration
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/path/to/gcp-service-account.json

# Cloud Storage
GCP_STORAGE_BUCKET=your-storage-bucket-name

# Cloud Logging
GCP_LOGGING_ENABLED=True

# Secret Manager
GCP_SECRET_MANAGER_ENABLED=True

# Vertex AI
VERTEX_AI_ENABLED=True
VERTEX_AI_LOCATION=us-central1

# ==================== Google Analytics 4 ====================

# GA4 Measurement Protocol
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
GA4_API_SECRET=your-ga4-api-secret

# GA4 Configuration (for client-side)
GA4_TRACKING_ID=G-XXXXXXXXXX

# ==================== Optional Services ====================

# Google Maps API (for future features)
GOOGLE_MAPS_API_KEY=your-maps-api-key

# YouTube Data API (for future features)
YOUTUBE_API_KEY=your-youtube-api-key

# ==================== Application Settings ====================

# Environment
ENVIRONMENT=development
DEBUG=True

# Session Configuration
SESSION_SECRET_KEY=your-secret-key-here

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=60
