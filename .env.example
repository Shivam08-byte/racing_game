# AI Service Configuration
# Copy this file to .env and fill in your values

# Ollama Configuration (for local LLM)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3:latest
OLLAMA_FLAG=False

# Gemini Configuration (for cloud AI)
GOOGLE_API_KEY=your-gemini-api-key-here
GEMINI_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash-lite:generateContent
GEMINI_FLAG=True

# Priority: If OLLAMA_FLAG=True and Ollama is reachable, it will be used.
# Otherwise, if GEMINI_FLAG=True, Gemini will be used.
# If both fail, the app falls back to offline heuristics.
